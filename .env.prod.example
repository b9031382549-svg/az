# ── Production env template for the AZ server ───────────────────────────────
# Copy to /opt/az/.env on the server and fill the blanks. NEVER commit the real
# .env. Anything not listed keeps its normal Laravel default.

APP_NAME="eInvoice AI"
APP_ENV=production
APP_DEBUG=false
APP_KEY=                         # php artisan key:generate --show
APP_URL=http://157.90.152.161    # switch to https://<domain> once DNS/TLS exist

# Logs go to container stdout (docker compose logs) — no storage volume needed.
LOG_CHANNEL=stderr
LOG_LEVEL=warning

# Postgres — service name on the compose network is `pgsql`.
DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=app
DB_USERNAME=app
DB_PASSWORD=                     # set a strong password (also used by the db container)
# Read-only role for the NL->SQL task (Task 1).
DB_RO_USERNAME=app_ro
DB_RO_PASSWORD=

# Sessions / cache live in Postgres; the queue runs on Redis (Horizon).
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=redis
# Redis (queue backend for Horizon) — internal compose service "redis".
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
# Must exceed the longest job timeout (SearchResolveJob = 300s — web search +
# reasoning) so a slow job is never re-dispatched while still running (no duplicate
# paid LLM/search calls).
REDIS_QUEUE_RETRY_AFTER=360

# Ollama — internal compose service, never published.
OLLAMA_URL=http://ollama:11434
OLLAMA_EMBED_MODEL=bge-m3
EMBED_DIMENSIONS=1024

# OpenRouter (cloud LLM) — keep this key only here on the server.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
# Query-expansion (extract) model — runs on every item (Task-2 classifier retrieval,
# NOT the NL->SQL chat). Reads noisy mixed AZ/RU names. On Nebius Llama with the rest
# of the decision stages; drop "nebius:" to move back to OpenRouter.
CLASSIFY_EXPAND_MODEL=nebius:meta-llama/Llama-3.3-70B-Instruct
# Store full prompt+response in the LLM decision log (llm_usage). Set false to
# keep only metadata (tokens/latency/tier/status) if payloads are too sensitive.
OPENROUTER_LOG_PAYLOADS=true

# Nebius Token Factory (alternative OpenAI-compatible LLM provider). Optional —
# only needed if a stage's model is prefixed "nebius:". Route any stage there by
# prefixing its model, e.g. CLASSIFY_EXPAND_MODEL=nebius:deepseek-ai/DeepSeek-V4-Pro
# (no prefix keeps that stage on OpenRouter). Both providers stay available.
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1
NEBIUS_API_KEY=

# Decision stages → Nebius Llama-3.3-70B (rerank tier1+2, broker, direct). Measured
# +14-16pp heading-accuracy vs deepseek-chat on the reranker (2026-07). Reversible:
# drop the "nebius:" prefix / set an OpenRouter id to move a stage back. expand +
# search stay on OpenRouter (search needs :online web lookup, absent on Nebius).
OPENROUTER_CLASSIFY_TIER1_MODEL=nebius:meta-llama/Llama-3.3-70B-Instruct
OPENROUTER_CLASSIFY_MODEL=nebius:meta-llama/Llama-3.3-70B-Instruct
CLASSIFY_BROKER_MODEL=nebius:meta-llama/Llama-3.3-70B-Instruct
CLASSIFY_BROKER_BRIEF_MODEL=nebius:meta-llama/Llama-3.3-70B-Instruct
CLASSIFY_BROKER_FACT_MODEL=nebius:meta-llama/Llama-3.3-70B-Instruct
CLASSIFY_DIRECT_MODEL=nebius:meta-llama/Llama-3.3-70B-Instruct
CLASSIFY_SEARCH_RESOLVER_MODEL=deepseek/deepseek-v4-flash:online
