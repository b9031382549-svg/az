# ── Production env template for the AZ server ───────────────────────────────
# Copy to /opt/az/.env on the server and fill the blanks. NEVER commit the real
# .env. Anything not listed keeps its normal Laravel default.

APP_NAME="eInvoice AI"
APP_ENV=production
APP_DEBUG=false
APP_KEY=                         # php artisan key:generate --show
APP_URL=http://157.90.152.161    # switch to https://<domain> once DNS/TLS exist

# Logs go to container stdout (docker compose logs) — no storage volume needed.
LOG_CHANNEL=stderr
LOG_LEVEL=warning

# Postgres — service name on the compose network is `pgsql`.
DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=app
DB_USERNAME=app
DB_PASSWORD=                     # set a strong password (also used by the db container)
# Read-only role for the NL->SQL task (Task 1).
DB_RO_USERNAME=app_ro
DB_RO_PASSWORD=

# Sessions / cache live in Postgres; the queue runs on Redis (Horizon).
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=redis
# Redis (queue backend for Horizon) — internal compose service "redis".
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
# Must exceed the longest job timeout (SearchResolveJob = 300s — web search +
# reasoning) so a slow job is never re-dispatched while still running (no duplicate
# paid LLM/search calls).
REDIS_QUEUE_RETRY_AFTER=360

# Ollama — internal compose service, never published.
OLLAMA_URL=http://ollama:11434
OLLAMA_EMBED_MODEL=bge-m3
EMBED_DIMENSIONS=1024

# OpenRouter (cloud LLM) — keep this key only here on the server.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
# Query-expansion (extract) model — runs on every item. Strong model reads noisy
# mixed AZ/RU names far better than gpt-4o-mini. Defaults to openai/gpt-4o.
CLASSIFY_EXPAND_MODEL=openai/gpt-4o
# Store full prompt+response in the LLM decision log (llm_usage). Set false to
# keep only metadata (tokens/latency/tier/status) if payloads are too sensitive.
OPENROUTER_LOG_PAYLOADS=true
